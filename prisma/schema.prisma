generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String
  name                   String
  role                   String
  lat                    Float?
  lng                    Float?
  address                String?
  status                 String   @default("SAFE")
  kycStatus              String   @default("Pending")
  locationTrackingStatus String   @default("Pending")
  emailVerified          Boolean  @default(false)

  // Profile fields
  dateOfBirth                 DateTime?
  gender                      String?
  bio                         String?
  profileImage                String?   // base64 data URI or URL
  nationality                 String?
  bloodGroup                  String?

  // Registration fields
  phone                       String?
  alternativePhone            String?
  citizenship                 String?
  aadhaarNumber               String?
  emergencyContactName        String?
  emergencyContactPhone       String?
  emergencyContactRelation    String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  emergencies            EmergencyEvent[]
  location               UserLocation?
  firs                   FIR[]
  threatZones            ThreatZone[]
}

model EmergencyEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float?
  lng       Float?
  accuracy  Float?
  stepsJson String   @default("[\"pending\",\"pending\",\"pending\",\"pending\"]")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  organization String
  message      String
  createdAt    DateTime @default(now())
}

model SystemActivity {
  id        String   @id @default(cuid())
  message   String
  kind      String
  detail    String?
  createdAt DateTime @default(now())
}

// IncidentType values: THEFT, ASSAULT, CYBERCRIME, HARASSMENT, ROBBERY, OTHER
// Stored as String because SQLite does not support enums.

model FIR {
  id               String       @id @default(cuid())
  firNumber        String       @unique
  userId           String
  complainantName  String
  complainantAddress String?
  complainantContact String?
  incidentType     String
  incidentDateTime DateTime
  location         String
  description      String
  accusedDetails   String?
  evidenceUrls     String?
  status           String       @default("PENDING")
  otpCode          String?
  otpSentAt        DateTime?
  verifiedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp              Otp?

  @@map("firs")
}

model Otp {
  id        String   @id @default(cuid())
  firId     String   @unique
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  fir       FIR      @relation(fields: [firId], references: [id], onDelete: Cascade)
}

// Real-time user location — one row per user, overwritten every 2 minutes
model UserLocation {
  userId    String   @id
  lat       Float
  lng       Float
  accuracy  Float?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_location")
}

// Threat score for a geographic area — auto-expires after 6 hours
model ThreatZone {
  id               String   @id @default(cuid())
  lat              Float
  lng              Float
  location         String
  score            Float
  zone             String   // GREEN | YELLOW | ORANGE | RED
  summary          String
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  status           String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  reportedByUserId String?
  reportedBy       User?    @relation(fields: [reportedByUserId], references: [id])
  newsSource       String?  // The actual news headline that triggered this threat

  @@map("threat_zones")
}

// Geo-fence zones for tourist safety — circle or polygon
model GeoFence {
  id          String   @id @default(cuid())
  name        String
  type        String   // "circle" | "polygon"
  centerLat   Float?   // For circle type
  centerLng   Float?   // For circle type
  radius      Float?   // For circle type (meters)
  vertices    String?  // JSON string of [{lat, lng}] for polygon type
  zone        String   @default("RED")  // RED | ORANGE | YELLOW
  active      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("geo_fences")
}
